# App Environment
NODE_ENV=development
PORT=3000

# Public URLs (For CORS and Frontend API calls)
NEXT_PUBLIC_API_URL=http://localhost:3001 # Cambiar a subdominio (ej: https://api.midominio.com) en produccion

# Database (PostgreSQL / Drizzle)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asisteme_db

# External APIs
EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_KEY=your_api_key_here

# Security
JWT_SECRET=super_secret_jwt_key

# Collective AI Memory (Qdrant VPS)
ENABLE_COLLECTIVE_MEMORY=false
QDRANT_URL=http://your-qdrant-vps-ip:6333
QDRANT_API_KEY=your_qdrant_api_key_here
